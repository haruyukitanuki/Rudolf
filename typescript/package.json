{
  "name": "@tanuden/rudolf",
  "version": "0.1.0",
  "description": "Type definitions for the RUDOLF (Railway Unified Display Object Link Format) wire schema.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/tanuden/rudolf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanuden/rudolf.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/tanuden/rudolf/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
